# ===== Application =====
APP_NAME=health-agent-api
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_CORS_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19006

# ===== Database (Supabase Postgres) =====
# postgresql+asyncpg://postgres:<password>@<host>:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/health_agent
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ===== Supabase =====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_JWT_ALGORITHM=HS256
SUPABASE_JWT_AUDIENCE=authenticated

# ===== DashScope (LLM) =====
DASHSCOPE_API_KEY=sk-xxx
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3

# ===== Embedding =====
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSIONS=1024

# ===== Logging =====
LOG_LEVEL=INFO
